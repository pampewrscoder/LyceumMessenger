# ── Database ──────────────────────────────────────────────────────────────
# PostgreSQL password (used by docker-compose for the `db` service)
POSTGRES_PASSWORD=lyceum_secret_change_me

# ── Auth ──────────────────────────────────────────────────────────────────
# Random secret for signing JWT tokens — generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=change_this_to_a_long_random_string

# ── Storage ───────────────────────────────────────────────────────────────
# Directory to store uploaded files (used inside the container)
UPLOAD_DIR=/app/uploads
